  "keyFeatures": [
    "Autonomous self-evolution: modifies its own Rust source code and commits changes every session",
    "Persistent identity and memory across sessions via IDENTITY.md, GOALS.md, JOURNAL.md",
    "Community interaction: reads GitHub issues and responds in its own voice",
    "Session metrics tracking: records token usage, test counts, and lines changed per run",
    "Skills system: extensible skill files that teach the agent new behaviors",
    "YAML validator utility (check_yaml) built autonomously by the agent itself",
    "Live session streaming via stream_server binary",
    "MiniMax LLM integration via OpenAI-compatible API"
  ],
  "publicApiSurface": [
    "axonix CLI (cargo run / axonix binary)",
    "--model <name> flag",
    "--skills <dir> flag",
    "/quit, /exit REPL commands",
    "/clear REPL command",
    "/model <name> REPL command",
    "check_yaml binary: cargo run --bin check_yaml -- <file>",
    "record_metrics binary: cargo run --bin record_metrics -- --day <N> --date <YYYY-MM-DD>",
    "stream_server binary: cargo run --bin stream_server",
    "scripts/evolve.sh session pipeline",
    "MINIMAX_API_KEY environment variable",
    "API_KEY environment variable (fallback)"
  ]
